rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data;
    }

    function isCoordinator() {
      return isAuth() && userDoc(request.auth.uid).role == 'coordinator';
    }

    function callerNurseId() {
      return userDoc(request.auth.uid).nurseId;
    }

    function isOwnerNurse(nurseId) {
      return isAuth() && callerNurseId() == nurseId;
    }

    // Coords podem alterar apenas estes campos em uma solicitação existente
    function solUpdateAllowed() {
      return request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['status', 'approvedAt', 'rejectedAt', 'decidedBy', 'observacaoCoord']);
    }

    // ── Coleções ───────────────────────────────────────────────────────────

    match /funcionarios/{nurseId} {
      allow read:  if isAuth();
      allow write: if isCoordinator();
    }

    match /escalas/{docId} {
      // docId format: {nurseId}_{year}_{month}
      allow read:  if isAuth() && (isCoordinator() || isOwnerNurse(docId.split('_')[0]));
      allow write: if isCoordinator();
    }

    match /solicitacoes/{docId} {
      allow read:   if isAuth() && (isCoordinator() || resource.data.nurseId == callerNurseId());

      // Enfermeira só pode criar pedido em nome dela mesma e sempre como pendente.
      // Coord também pode criar (ex: lançar férias administrativamente).
      allow create: if isAuth()
                    && request.resource.data.status == 'pendente'
                    && (isCoordinator()
                        || request.resource.data.nurseId == callerNurseId());

      // Apenas coord aprova/rejeita; campos congelados além dos da whitelist.
      allow update: if isCoordinator() && solUpdateAllowed();

      allow delete: if isCoordinator();
    }

    match /usuarios/{uid} {
      allow read:  if isAuth() && (request.auth.uid == uid || isCoordinator());
      allow write: if isCoordinator();
    }

    // Default deny — qualquer outra coleção é negada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
